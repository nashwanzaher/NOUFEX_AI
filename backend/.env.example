# NOUFEX_AI — environment variables (copy to .env)

ENV=development
DEBUG=true
PROJECT_NAME=NOUFEX AI
API_V1_PREFIX=/v1

# JWT (EdDSA recommended; generate with: openssl genpkey -algorithm ed25519 -out jwt.pem)
SECRET_KEY=dev-insecure-change-me-now
JWT_ALGORITHM=EdDSA
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Postgres (async URL used at runtime; sync URL used by Alembic)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/noufex_ai
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:postgres@db:5432/noufex_ai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_MAX_OUTPUT_TOKENS=1024
OPENAI_REQUEST_TIMEOUT_SECONDS=30

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry
OTEL_SERVICE_NAME=noufex-ai
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# Rate limits
RATE_LIMIT_PER_MINUTE_PER_IP=60
RATE_LIMIT_PER_MINUTE_PER_USER=120

# File uploads
FILE_UPLOAD_MAX_SIZE_MB=25

# Docs (set to empty to disable in production)
DOCS_URL=/docs
REDOC_URL=/redoc

# Browser automation
BROWSER_DEFAULT_HEADLESS=false
BROWSER_DEFAULT_VIEWPORT_WIDTH=1280
BROWSER_DEFAULT_VIEWPORT_HEIGHT=720

# Computer control
COMPUTER_ENABLE_COMMAND_EXECUTION=true
COMPUTER_SCREENSHOT_QUALITY=80
COMPUTER_MOUSE_SPEED=0.5

# Agent skills
AGENT_SKILLS_MAX_ITERATIONS=10
AGENT_SKILLS_AUTO_CONFIRM_SAFE=false

# Design system
DESIGN_DEFAULT_PRIMARY_COLOR=#3B82F6
DESIGN_DEFAULT_FONT_FAMILY=Inter, system-ui, sans-serif
DESIGN_DEFAULT_SCHEME=light
